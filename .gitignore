# ── Build artefacts ──────────────────────────────────────────────────────────
build/
out/
cmake-build-*/
*.o
*.a
*.so
*.dylib
*.dll

# ── CMake internal files ──────────────────────────────────────────────────────
CMakeCache.txt
CMakeFiles/
CTestTestfile.cmake
cmake_install.cmake
install_manifest.txt
compile_commands.json   # generated by cmake; copy to root manually if needed
_deps/

# ── IDE / editor ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Toolchain generated ───────────────────────────────────────────────────────
*.dSYM/         # macOS debug symbols
*.pdb           # Windows debug symbols
*.ilk
*.exp

# ── Test binaries & coverage ─────────────────────────────────────────────────
Testing/
CoverageReport/
*.gcda
*.gcno
*.profdata
*.profraw

# ── Claude Code internal files ────────────────────────────────────────────────
memory/
.claude/settings.local.json  # user-local permissions; not shared

# ── Temporary / scratch ───────────────────────────────────────────────────────
*.tmp
*.log
scratch/

# ── Gemini materials ───────────────────────────────────────────────────────
materials/

# ── Local design docs (planning material, not for distribution) ───────────────
docs/
